@model IEnumerable<TaskManager.Models.TaskItem>

@{
    ViewData["Title"] = "Список задач";
}

<h1>Всі задачі</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Створити задачу</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Пріоритет</th>
            <th>Статус</th>
            <th>Дедлайн</th>
            <th>Творець</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Title</td>
                <td>@item.Priority</td>
                <td>@item.Status</td>
                <td>@item.Deadline.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@item.Creator?.Email</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редагувати</a>
                </td>
            </tr>
        }
    </tbody>
</table>