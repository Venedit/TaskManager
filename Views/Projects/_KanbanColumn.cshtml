@using TaskManager.Models
@model (ICollection<TaskItem> Tasks, TaskManager.Models.TaskStatus Status, string Title, string CssClass)

<div class="kanban-column">
    <div class="kanban-column-header d-flex justify-content-between align-items-center">
        <span>@Model.Title</span>
        <span class="badge rounded-pill bg-white text-secondary border">@Model.Tasks.Count(t => t.Status == Model.Status)</span>
    </div>
    
    <div class="overflow-auto pe-1" style="flex-grow: 1;">
        @foreach (var task in Model.Tasks.Where(t => t.Status == Model.Status))
        {
            <div class="card shadow-sm border-0 mb-3 kanban-card @Model.CssClass transition-hover position-relative">
                <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id" class="text-decoration-none text-dark p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="task-priority bg-light text-dark border">@task.Priority</span>
                        @if (task.Deadline < DateTime.Now && task.Status != TaskManager.Models.TaskStatus.Completed)
                        {
                            <span class="text-danger fw-bold" style="font-size: 0.7rem;">🔥 @task.Deadline.ToString("dd.MM")</span>
                        }
                    </div>
                    
                    <h6 class="fw-bold mb-1">@task.Title</h6>
                    <p class="small text-muted mb-2 text-truncate" title="@task.Description">@task.Description</p>
                    
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div class="small">
                            @if (task.Assignee != null)
                            {
                                <span class="badge rounded-pill bg-light text-dark border">
                                    👤 @task.Assignee.Email.Split('@')[0]
                                </span>
                            }
                            else
                            {
                                <span class="text-muted italic small">не призначено</span>
                            }
                        </div>
                    </div>
                </a>

                <div class="px-3 pb-3 mt-n2">
                    <form asp-controller="Tasks" asp-action="UpdateStatus" method="post" class="m-0 border-top pt-2">
                        <input type="hidden" name="id" value="@task.Id" />
                        <div class="d-flex justify-content-end gap-1">
                            @if (task.Status == TaskManager.Models.TaskStatus.New)
                            {
                                <button name="newStatus" value="@TaskManager.Models.TaskStatus.InProgress" class="btn btn-sm btn-link text-primary p-0 text-decoration-none fw-bold" style="font-size: 0.75rem;">Взяти в роботу →</button>
                            }
                            else if (task.Status == TaskManager.Models.TaskStatus.InProgress)
                            {
                                <button name="newStatus" value="@TaskManager.Models.TaskStatus.Review" class="btn btn-sm btn-link text-warning p-0 text-decoration-none fw-bold" style="font-size: 0.75rem;">На перевірку →</button>
                            }
                            else if (task.Status == TaskManager.Models.TaskStatus.Review)
                            {
                                <button name="newStatus" value="@TaskManager.Models.TaskStatus.Completed" class="btn btn-sm btn-link text-success p-0 text-decoration-none fw-bold" style="font-size: 0.75rem;">Завершити ✓</button>
                            }
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>