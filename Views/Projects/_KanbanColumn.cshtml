@using TaskManager.Models
@model (ICollection<TaskItem> Tasks, TaskManager.Models.TaskStatus Status, string Title, string CssClass)

<div class="kanban-column">
    <div class="kanban-column-header d-flex justify-content-between align-items-center">
        <span class="text-uppercase text-secondary">@Model.Title</span>
        <span class="badge bg-white text-dark border rounded-pill">@Model.Tasks.Count(t => t.Status ==
                        Model.Status)</span>
        </div>
    
        <div class="kanban-card-body custom-scrollbar">
            @foreach (var task in Model.Tasks.Where(t => t.Status == Model.Status))
            {
                <div class="card border-0 board-card @Model.CssClass position-relative">
                
                    <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id" class="stretched-link"></a>
                
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-light text-dark border" style="font-size: 0.65rem;">@task.Priority</span>
                        @if (task.Deadline < DateTime.Now && task.Status != TaskManager.Models.TaskStatus.Completed)
                        {
                            <span class="text-danger fw-bold" style="font-size: 0.7rem;"
                                  title="Протерміновано">@task.Deadline.ToString("dd.MM")</span>
                        }
                    </div>
                
                    <h6 class="fw-bold mb-3 lh-sm" style="font-size: 0.9rem;">@task.Title</h6>
                
                    <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top position-relative"
                         style="z-index: 2;">
                        <div class="small">
                            @if (task.Assignee != null)
                            {
                                <span class="badge bg-light text-secondary border p-1" title="@task.Assignee.Email">
                                    👤 @task.Assignee.Email.Substring(0, 2).ToUpper()
                                </span>
                            }
                            else
                            {
                                <form asp-controller="Tasks" asp-action="Claim" asp-route-id="@task.Id" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-primary py-0 px-2 fw-bold"
                                            style="font-size: 0.7rem;">
                                        Прийняти
                                    </button>
                                </form>
                            }
                        </div>

                        <form asp-controller="Tasks" asp-action="UpdateStatus" method="post" class="m-0">
                            <input type="hidden" name="id" value="@task.Id" />
                            @if (task.Status == TaskManager.Models.TaskStatus.New)
                            {
                                <button name="newStatus" value="@TaskManager.Models.TaskStatus.InProgress"
                                        class="btn btn-sm btn-light py-0 px-2 text-primary border shadow-sm"
                                        title="Взяти в роботу">→</button>
                            }
                            else if (task.Status == TaskManager.Models.TaskStatus.InProgress)
                            {
                                <button name="newStatus" value="@TaskManager.Models.TaskStatus.Review"
                                        class="btn btn-sm btn-light py-0 px-2 text-warning border shadow-sm"
                                        title="Відправити на перевірку">→</button>
                            }
                            else if (task.Status == TaskManager.Models.TaskStatus.Review)
                            {
                                <button name="newStatus" value="@TaskManager.Models.TaskStatus.Completed"
                                        class="btn btn-sm btn-light py-0 px-2 text-success border shadow-sm"
                                        title="Завершити">✓</button>
                            }
                        </form>
                    </div>
                </div>
            }
        </div>
    </div>