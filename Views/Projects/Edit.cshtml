@model TaskManager.Models.Project
@using Microsoft.AspNetCore.Identity
@using TaskManager.Models
@inject UserManager<ApplicationUser> _userManager

@{
    ViewData["Title"] = "Налаштування проєкту";
    var currentUserId = _userManager.GetUserId(User);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Налаштування проєкту</h2>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
        ← Назад до дошки
    </a>
</div>

<div class="row">
    <div class="col-md-5 mb-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-bold">Основна інформація</h6>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label text-muted small fw-bold">НАЗВА ПРОЄКТУ</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label text-muted small fw-bold">ОПИС</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">Зберегти зміни</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-light">
                <h6 class="mb-0 fw-bold">Команда проєкту</h6>
            </div>
            <div class="card-body">
                
                <form asp-action="AddMember" method="post" class="mb-4 p-3 bg-light rounded border">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <h6 class="fw-bold mb-3 small text-uppercase">Запросити учасника</h6>
                    <div class="row g-2 align-items-end">
                        <div class="col-md-6">
                            <label class="form-label small">Email користувача</label>
                            <input name="email" type="email" class="form-control form-control-sm" required placeholder="user@example.com"/>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small">Роль</label>
                            <select name="role" class="form-select form-select-sm">
                                @foreach (var item in Html.GetEnumSelectList<ProjectRole>())
                                {
                                    // Овнер не може додати іншого Овнера
                                    if (item.Value != ((int)ProjectRole.Owner).ToString())
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-sm btn-primary w-100">Додати</button>
                        </div>
                    </div>
                </form>

                <h6 class="fw-bold mb-3 small text-uppercase">Поточні учасники</h6>
                <ul class="list-group list-group-flush">
                    @if (Model.Members != null)
                    {
                        @foreach (var m in Model.Members)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <span class="fw-medium">👤 @(m.User?.Email)</span>
                                    @if (m.UserId == currentUserId)
                                    {
                                        <span class="badge bg-secondary ms-2">Це ти</span>
                                    }
                                </div>
                                
                                <div class="d-flex align-items-center gap-2">
                                    @if (m.UserId != currentUserId)
                                    {
                                        <form asp-action="UpdateRole" method="post" class="m-0">
                                            <input type="hidden" name="projectId" value="@Model.Id" />
                                            <input type="hidden" name="userId" value="@m.UserId" />
                                            <select name="newRole" class="form-select form-select-sm" onchange="this.form.submit()" style="width: 140px;">
                                                @foreach (var item in Html.GetEnumSelectList<ProjectRole>())
                                                {
                                                    if (item.Value != ((int)ProjectRole.Owner).ToString())
                                                    {
                                                        if (item.Value == ((int)m.Role).ToString())
                                                        {
                                                            <option value="@item.Value" selected>@item.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@item.Value">@item.Text</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                        </form>
                                        
                                        <form asp-action="RemoveMember" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цього користувача з команди?');" class="m-0">
                                            <input type="hidden" name="projectId" value="@Model.Id" />
                                            <input type="hidden" name="userId" value="@m.UserId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Видалити">✖</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="badge bg-dark">@m.Role</span>
                                    }
                                </div>
                            </li>
                        }
                    }
                </ul>
                
            </div>
        </div>
        
        <div class="card border-danger shadow-sm mt-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-danger fw-bold mb-1">Видалити проєкт</h6>
                    <p class="text-muted small mb-0">Ця дія видалить проєкт та всі його задачі назавжди.</p>
                </div>
                <form asp-action="Delete" method="post" onsubmit="return confirm('ВИДАЛИТИ ПРОЄКТ НАЗАВЖДИ? Цю дію неможливо скасувати!');">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Видалити</button>
                </form>
            </div>
        </div>
        
    </div>
</div>