@{
    ViewData["Title"] = "Головна";
}

@* Перевіряємо статус користувача прямо в HTML *@
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="container mt-4">
        <h2 class="mb-4">Привіт, @User.Identity.Name! 👋</h2>

        <div class="row">
            <div class="col-lg-8">
                <h4 class="text-muted mb-3">Ваші проєкти</h4>
                <div class="row">
                    @foreach (var proj in ViewBag.Projects)
                    {
                        <div class="col-md-6 mb-3">
                            <div class="card shadow-sm border-0 h-100 bg-light">
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">@proj.Name</h5>
                                    <p class="card-text text-truncate">@proj.Description</p>
                                    <a asp-controller="Projects" asp-action="Details" asp-route-id="@proj.Id"
                                       class="btn btn-sm btn-primary">Увійти в проєкт</a>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-md-6 mb-3">
                        <div class="card shadow-sm border-dashed h-100 d-flex align-items-center justify-content-center bg-transparent"
                             style="border: 2px dashed #dee2e6;">
                            <a asp-controller="Projects" asp-action="Create"
                                   class="text-decoration-none text-muted p-4 text-center">
                                <h1 class="display-6">+</h1>
                                <span>Створити проєкт</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <h4 class="text-muted mb-3">Дедлайни 🔥</h4>
                <div class="list-group shadow-sm">
                    @foreach (var task in ViewBag.UrgentTasks)
                    {
                        <a asp-controller="Tasks" asp-action="Edit" asp-route-id="@task.Id"
                               class="list-group-item list-group-item-action border-0 mb-2 rounded shadow-sm">
                            <div class="d-flex w-100 justify-content-between">
                                <h6 class="mb-1 fw-bold">@task.Title</h6>
                                <small class="text-danger">@task.Deadline.ToShortDateString()</small>
                            </div>
                            <small class="text-muted">Проєкт: @task.Project?.Name</small>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    @* Дизайн для незареєстрованих гостей *@
    <div class="text-center mt-5">
        <h1 class="display-4 fw-bold">Колективний Task Manager 🚀</h1>
        <p class="lead mt-3">Організуй роботу своєї команди швидко, надійно та зручно.</p>
        <hr class="my-4">
        <p class="mb-4">Щоб почати створювати задачі та керувати процесами, будь ласка, увійдіть в систему.</p>
        
        <a class="btn btn-primary btn-lg mx-2" asp-area="Identity" asp-page="/Account/Register">Зареєструватися</a>
        <a class="btn btn-outline-secondary btn-lg mx-2" asp-area="Identity" asp-page="/Account/Login">Увійти</a>
    </div>
}